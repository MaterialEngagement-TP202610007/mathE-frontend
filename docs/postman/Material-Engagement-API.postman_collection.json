{
  "info": {
    "name": "VAK Engagement API",
    "_postman_id": "vak-engagement-api-collection",
    "description": "Backend REST API — educational platform with VAK learning-style detection (Gemini AI + XGBoost).\n\n## Auth\nJWT is delivered as an HttpOnly cookie `auth_token`. Postman stores it automatically in the cookie jar after `Auth > Login`, and replays it on every subsequent request — no manual token handling needed.\n\n## Variables\n- `baseUrl` (default `http://localhost:3000`)\nIDs are captured into collection variables by test scripts where useful (e.g. `questionnaireId`, `questionId`, `resultId`).\n\nRoles: Admin=1, Teacher=2, Student=3.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "userId",
      "value": "",
      "type": "string"
    },
    {
      "key": "schoolId",
      "value": "1",
      "type": "string"
    },
    {
      "key": "questionId",
      "value": "",
      "type": "string"
    },
    {
      "key": "questionnaireId",
      "value": "",
      "type": "string"
    },
    {
      "key": "answerId",
      "value": "",
      "type": "string"
    },
    {
      "key": "resultId",
      "value": "",
      "type": "string"
    },
    {
      "key": "notificationId",
      "value": "",
      "type": "string"
    },
    {
      "key": "datasetId",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200 OK', () => pm.response.code === 200);",
                  "const u = pm.response.json().user;",
                  "if (u && u.id) pm.collectionVariables.set('userId', u.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"Passw0rd\"\n}"
            },
            "description": "Authenticate. Sets the auth_token HttpOnly cookie. Body returns { user }, no token."
          }
        },
        {
          "name": "Me (validate session)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/auth/me",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "me"
              ]
            },
            "description": "Validate the current session. Returns { user } if the cookie is valid and the account is active; 401 otherwise. Use on app load."
          }
        },
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "register"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"student@example.com\",\n  \"password\": \"Passw0rd\",\n  \"name\": \"Jane Doe\",\n  \"birthDate\": \"2010-05-01\",\n  \"roleId\": 3,\n  \"phoneNumber\": \"+593987654321\",\n  \"schoolId\": 1,\n  \"academicGradeId\": 2\n}"
            },
            "description": "Register a user. Students (roleId=3) are created inactive and cannot log in until an admin activates them."
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/auth/logout",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "logout"
              ]
            },
            "description": "Clears the auth_token cookie. Returns { ok: true }."
          }
        }
      ]
    },
